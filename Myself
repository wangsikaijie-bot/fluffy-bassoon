<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anthony | Personal Website</title>
  <style>
    :root{
      --bg:#000000;
      --bg-soft:#0a0a0f;
      --text:#f5f5f7;
      --muted:#a1a1a6;
      --line:rgba(255,255,255,.10);
      --card:rgba(255,255,255,.05);
      --accent:#2997ff;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --radius:28px;
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Roboto,Helvetica,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top, #1a1a22 0%, #07070b 35%, #000 75%);
      overflow-x:hidden;
    }

    a{
      text-decoration:none;
      color:inherit;
    }

    .nav{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      z-index:999;
      background:rgba(0,0,0,.55);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .nav-inner{
      max-width:1200px;
      margin:0 auto;
      padding:14px 20px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .brand{
      font-size:18px;
      font-weight:700;
      letter-spacing:-0.02em;
    }

    .nav-links{
      display:flex;
      gap:18px;
      color:var(--muted);
      font-size:14px;
    }

    .nav-links a:hover{
      color:#fff;
    }

    section{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:110px 20px 70px;
      position:relative;
    }

    .wrap{
      width:100%;
      max-width:1200px;
      margin:0 auto;
    }

    .hero{
      text-align:center;
    }

    .badge{
      display:inline-block;
      padding:8px 14px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.04);
      color:#d2d2d7;
      font-size:13px;
      margin-bottom:24px;
    }

    h1{
      font-size:clamp(54px,10vw,120px);
      line-height:.95;
      letter-spacing:-0.05em;
      font-weight:700;
      margin-bottom:18px;
    }

    .hero-sub{
      max-width:800px;
      margin:0 auto;
      font-size:clamp(18px,2.5vw,30px);
      line-height:1.45;
      color:#d2d2d7;
    }

    .hero-actions{
      margin-top:34px;
      display:flex;
      justify-content:center;
      gap:14px;
      flex-wrap:wrap;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:150px;
      padding:14px 24px;
      border-radius:999px;
      font-size:16px;
      font-weight:600;
      transition:.28s ease;
    }

    .btn-primary{
      background:var(--accent);
      color:#fff;
      box-shadow:0 10px 30px rgba(41,151,255,.28);
    }

    .btn-primary:hover{
      transform:translateY(-2px);
      filter:brightness(1.05);
    }

    .btn-secondary{
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      color:var(--text);
    }

    .btn-secondary:hover{
      transform:translateY(-2px);
      background:rgba(255,255,255,.08);
    }

    .scroll-tip{
      margin-top:40px;
      color:#8e8e93;
      font-size:13px;
      letter-spacing:.08em;
      text-transform:uppercase;
      animation:breathe 2s ease-in-out infinite;
    }

    @keyframes breathe{
      0%,100%{opacity:.55;transform:translateY(0);}
      50%{opacity:1;transform:translateY(4px);}
    }

    .glow{
      position:absolute;
      width:520px;
      height:520px;
      background:radial-gradient(circle, rgba(41,151,255,.22), rgba(41,151,255,0) 68%);
      filter:blur(20px);
      z-index:-1;
      animation:float 7s ease-in-out infinite;
    }

    .glow.one{
      top:10%;
      left:50%;
      transform:translateX(-50%);
    }

    .glow.two{
      right:-120px;
      bottom:8%;
      width:420px;
      height:420px;
      animation-delay:1.5s;
    }

    @keyframes float{
      0%,100%{transform:translate(-50%,0);}
      50%{transform:translate(-50%,-18px);}
    }

    .panel{
      width:100%;
      background:linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:30px;
    }

    .section-title{
      font-size:clamp(36px,5vw,68px);
      line-height:1;
      letter-spacing:-0.05em;
      margin-bottom:18px;
    }

    .section-text{
      font-size:18px;
      line-height:1.85;
      color:#d2d2d7;
    }

    .two-col{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:24px;
      align-items:stretch;
    }

    .mini{
      color:var(--muted);
      font-size:13px;
      letter-spacing:.05em;
      text-transform:uppercase;
      margin-bottom:14px;
    }

    .list{
      display:grid;
      gap:14px;
      margin-top:18px;
    }

    .list-item{
      padding:16px 18px;
      border-radius:20px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
      color:#e8e8ed;
      font-size:16px;
      line-height:1.6;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:20px;
    }

    .card{
      padding:24px;
      border-radius:24px;
      background:linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03));
      border:1px solid var(--line);
      box-shadow:var(--shadow);
    }

    .card h3{
      font-size:26px;
      margin-bottom:12px;
      letter-spacing:-0.03em;
    }

    .card p{
      color:#d2d2d7;
      font-size:17px;
      line-height:1.8;
    }

    .quote-box{
      margin:0 auto;
      width:min(900px,100%);
      padding:34px 24px;
      border-radius:32px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
      box-shadow:var(--shadow);
      text-align:center;
    }

    .quote{
      font-size:clamp(22px,3vw,36px);
      line-height:1.55;
      letter-spacing:-0.03em;
    }

    .contact{
      text-align:center;
    }

    .contact p{
      max-width:760px;
      margin:0 auto 26px;
      color:#d2d2d7;
      font-size:20px;
      line-height:1.8;
    }

    .email{
      font-size:clamp(20px,2.5vw,32px);
      font-weight:600;
      word-break:break-word;
      margin:22px 0;
    }

    footer{
      padding:28px 20px 42px;
      text-align:center;
      color:#8e8e93;
      font-size:14px;
    }

    .reveal{
      opacity:0;
      transform:translateY(32px) scale(.98);
      transition:opacity .9s ease, transform .9s ease;
    }

    .reveal.visible{
      opacity:1;
      transform:translateY(0) scale(1);
    }

    @media (max-width: 900px){
      .two-col{
        grid-template-columns:1fr;
      }

      .cards{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 560px){
      .nav-links{
        display:none;
      }

      .hero-actions{
        flex-direction:column;
        align-items:center;
      }

      .btn{
        width:100%;
        max-width:280px;
      }

      .panel,.card{
        border-radius:22px;
      }

      .section-text,.card p,.contact p{
        font-size:17px;
      }
    }
  </style>
</head>
<body>
  <nav class="nav">
